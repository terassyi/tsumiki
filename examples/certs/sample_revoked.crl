# Test CRL fixture with one revoked entry, generated with OpenSSL
# (reusing the ca.key / ca.crt / openssl.cnf from sample.crl):
#
#   # index.txt with a revoked entry (serial 1001, reason keyCompromise):
#   printf 'R\t300101000000Z\t250601000000Z,keyCompromise\t1001\tunknown\t/CN=Revoked Leaf\n' > index.txt
#   echo 1002 > crlnumber
#   openssl ca -config openssl.cnf -gencrl -keyfile ca.key -cert ca.crt -out sample_revoked.crl
#
# (v2 CRL, crlNumber = 0x1002 = 4098; one revoked cert serial 0x1001 with
#  reasonCode = keyCompromise as a crlEntryExtension)
# nextUpdate is set ~100 years out (default_crl_days = 36500) so the
# `crl inspect --check-expiry` test stays time-independent.
