# Test CRL fixture generated with OpenSSL:
#
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout ca.key -out ca.crt \
#       -days 36500 -subj "/CN=Tsumiki Test CA"
#
#   # openssl.cnf:
#   #   [ca]
#   #   default_ca = CA_default
#   #   [CA_default]
#   #   database      = index.txt
#   #   default_md    = sha256
#   #   crlnumber     = crlnumber
#   #   default_crl_days = 36500
#
#   printf '' > index.txt
#   echo 1000 > crlnumber
#   openssl ca -config openssl.cnf -gencrl -keyfile ca.key -cert ca.crt -out sample.crl
#
# (v2 CRL, no revoked entries, crlNumber = 0x1000 = 4096)
# nextUpdate is set ~100 years out (default_crl_days = 36500) so the
# `crl inspect --check-expiry` test stays time-independent.
