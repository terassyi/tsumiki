# Test CRL fixture generated with OpenSSL:
#
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout ca.key -out ca.crt \
#       -days 1 -subj "/CN=Tsumiki Test CA"
#
#   # openssl.cnf:
#   #   [ca]
#   #   default_ca = CA_default
#   #   [CA_default]
#   #   database      = index.txt
#   #   default_md    = sha256
#   #   crlnumber     = crlnumber
#   #   default_crl_days = 30
#
#   printf '' > index.txt
#   echo 1000 > crlnumber
#   openssl ca -config openssl.cnf -gencrl -keyfile ca.key -cert ca.crt -out sample.crl
#
# (v2 CRL, no revoked entries, crlNumber = 0x1000 = 4096)
